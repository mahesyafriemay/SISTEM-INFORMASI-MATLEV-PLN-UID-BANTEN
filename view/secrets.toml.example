# Salin file ini jadi ".streamlit/secrets.toml" (lokal) atau paste isinya ke
# menu "Secrets" di dashboard Streamlit Cloud (kalau deploy online).
#
# Ambil nilai SUPABASE_URL dan SUPABASE_ANON_KEY dari:
# Dashboard Supabase -> pilih project kamu -> Project Settings -> API

SUPABASE_URL = "https://xxxxxxxxxxxx.supabase.co"
SUPABASE_ANON_KEY = "isi-anon-public-key-di-sini"
